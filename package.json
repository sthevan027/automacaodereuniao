{
  "name": "automacao-de-reuniao",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "migrate": "pnpm -C backend migrate",
    "sync": "pnpm -C backend sync",
    "dev:backend": "pnpm -C backend dev",
    "dev:frontend": "pnpm -C frontend dev"
  }
}

