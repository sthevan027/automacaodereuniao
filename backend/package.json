{
  "name": "automacao-reuniao-backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "migrate": "ts-node -T src/db/migrate.ts",
    "sync": "ts-node -T src/jobs/runSyncOnce.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
